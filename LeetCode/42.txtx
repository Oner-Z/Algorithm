class Solution {
public:
    int trap(vector<int>& height) {
        int n = height.size();
        int i = 0, j = n - 1;
        int res = 0;
        int lmax = 0, rmax = 0;
        while (i < j){
            lmax = max(lmax, height[i]);
            rmax = max(rmax, height[j]);
            if (height[i] <= height[j]){
                res += lmax - height[i];
                i ++ ;
            }
            else {
                res += rmax - height[j];
                j -- ;
            }
        }
        return res;
    }
};